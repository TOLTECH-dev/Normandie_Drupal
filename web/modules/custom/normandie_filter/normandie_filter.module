<?php

/**
 * @file
 * Filter the liste_actus view to display only news items.
 *
 * Filters the liste_actus view to display only nodes with field_tags=2
 * (News/Actualités). Applied to ALL displays (page, block, default)
 * to ensure consistency.
 */

declare(strict_types=1);

use Drupal\views\ViewExecutable;
use Drupal\views\Plugin\views\query\QueryPluginBase;

/**
 * Implements hook_views_query_alter().
 *
 * Filters the liste_actus view to display ONLY news items
 * (field_tags = 2 = Actualités).
 */
function normandie_filter_views_query_alter(ViewExecutable $view, QueryPluginBase $query) {
  // Apply ONLY to the liste_actus view.
  if ($view->id() != 'liste_actus') {
    return;
  }

  // Add filter by field_tags_target_id = 2 on all displays.
  $database = \Drupal::database();
  $subquery = $database->select('node__field_tags', 'nft');
  $subquery->fields('nft', ['entity_id']);
  $subquery->condition('nft.field_tags_target_id', 2);

  $query->addWhere(1, 'node_field_data.nid', $subquery, 'IN');
}
