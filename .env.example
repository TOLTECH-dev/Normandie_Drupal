# ============================================================================
# DRUPAL 7 → 10 PRODUCTION MIGRATION - ENVIRONMENT CONFIGURATION
# ============================================================================
#
# Copy this file to `.env` and fill in your actual values:
#   cp .env.example .env
#
# SECURITY: .env should NEVER be committed to version control!
#
# ============================================================================
# DRUPAL 10 (Target Database)
# ============================================================================

# Database host (localhost or remote server)
DB_D10_HOST=localhost

# Database name
DB_D10_NAME=normandie_d10_prod

# Database user
DB_D10_USER=drupal

# Database password (CHANGE THIS!)
DB_D10_PASSWORD=change_me_production_password

# Database port (usually 3306 for MySQL)
DB_D10_PORT=3306

# ============================================================================
# SYMFONY DATABASE (External Database)
# ============================================================================

# Database host (leave empty to use DB_D10_HOST)
DB_SYMFONY_HOST=

# Database name
DB_SYMFONY_NAME=normandie_symfony

# Database user (leave empty to use DB_D10_USER)
DB_SYMFONY_USER=

# Database password (leave empty to use DB_D10_PASSWORD)
DB_SYMFONY_PASSWORD=

# Database port (leave empty to use DB_D10_PORT)
DB_SYMFONY_PORT=

# Note: Empty values will fallback to DB_D10 credentials
# This is configured in settings.php as $databases['symfony']['default']

# ============================================================================
# DRUPAL 7 (Source Database)
# ============================================================================

# Database host (localhost if same server, or remote IP/hostname)
DB_D7_HOST=localhost

# Database name
DB_D7_NAME=normandie_d7_prod

# Database user
DB_D7_USER=drupal

# Database password (CHANGE THIS!)
DB_D7_PASSWORD=change_me_d7_password

# Database port (usually 3306 for MySQL)
DB_D7_PORT=3306

# ============================================================================
# DRUPAL 10 CONFIGURATION
# ============================================================================

# Unique hash salt for Drupal (generate with: openssl rand -base64 32)
HASH_SALT=change_me_generate_with_openssl_rand_base64_32

# Environment (dev, prod)
DRUPAL_ENV=prod

# ============================================================================
# TRUSTED HOST PATTERNS (Security)
# ============================================================================

# Allowed hostnames (comma-separated, no spaces needed)
# Protects against HTTP Host Header attacks
# List all domains that should access your site
#
# Examples:
# - Local dev: localhost,127.0.0.1,normandie-d10.local
#
TRUSTED_HOST_PATTERNS=localhost,127.0.0.1,normandie-d10.local

# ============================================================================
# MAIL CONFIGURATION
# ============================================================================

# Mail transport DSN for SMTP/Mailhog
# Format: smtp://[user:password@]host:port[?param=value&...]
#
# Paramètres optionnels (query string) :
#   encryption=tls        → STARTTLS (port 587) ou SSL/TLS (port 465)
#   encryption=ssl        → SSL direct (port 465)
#   username=xxx          → Authentification SMTP
#   password=xxx          → Mot de passe SMTP
#   ssl_no_verify=1       → Désactive la vérification du certificat SSL
#                           (certificats auto-signés, relais interne, port 25)
#
# Exemples :
# - Local/dev (Mailhog)         : smtp://localhost:1025
# - Prod relais interne port 25 : smtp://votre-serveur-smtp:25
#   (port 25 = sans auth, sans TLS → ssl_no_verify automatique)
# - Prod relais interne SSL     : smtp://votre-serveur-smtp:465?encryption=ssl&ssl_no_verify=1
# - Production (Gmail)          : smtp://smtp.gmail.com:587?encryption=tls&username=user@gmail.com&password=yourpassword
# - Production (Office365)      : smtp://smtp.office365.com:587?encryption=tls&username=user@company.com&password=yourpassword
#
MAILER_DSN=smtp://localhost:1025

# ============================================================================
# END OF CONFIGURATION
# ============================================================================